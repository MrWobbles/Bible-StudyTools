{
  "name": "bible-study-tools",
  "version": "1.0.0",
  "description": "Interactive Bible study presentation system with synchronized video playback and teacher controls",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "check:syntax": "node scripts/ci/run-syntax-checks.js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:p0": "playwright test tests/e2e/.*\\.p0\\.spec\\.js",
    "test:e2e:priority": "playwright test tests/e2e/.*\\.p[0-2]\\.spec\\.js",
    "test:e2e:headed": "playwright test --headed",
    "test:smoke:light": "node scripts/ci/api-smoke.js --mode=light",
    "test:smoke:heavy": "node scripts/ci/api-smoke.js --mode=heavy",
    "test:light": "npm run check:syntax && npm run test:unit && npm run test:smoke:light && npm run test:e2e:priority",
    "test:heavy": "npm run check:syntax && npm run test:unit && npm run test:smoke:heavy && npm run test:e2e:priority && npm run test:e2e"
  },
  "keywords": [
    "bible-study",
    "interactive",
    "presentation"
  ],
  "author": "Wes Huffman",
  "license": "ISC",
  "dependencies": {
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-color": "^3.20.0",
    "@tiptap/extension-highlight": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/extension-table-cell": "^3.20.0",
    "@tiptap/extension-table-header": "^3.20.0",
    "@tiptap/extension-table-row": "^3.20.0",
    "@tiptap/extension-text-style": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "mongodb": "^7.1.0",
    "ytdl-core": "^4.11.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  }
}
