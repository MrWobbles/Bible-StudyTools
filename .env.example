# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Get this from: Atlas Dashboard → Your Cluster → Connect → Drivers → Node.js
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/bible-study?retryWrites=true&w=majority

# Optional: override the database name (default: "bible-study")
# MONGODB_DB_NAME=bible-study
