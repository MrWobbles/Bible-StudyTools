# Copy this file to .env and fill in your values

# Supabase project URL (Settings -> API -> Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key (Settings -> API -> Project API keys -> anon/public)
SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (Settings -> API -> Project API keys -> service_role)
# Keep this secret and only use it on the server.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Postgres connection string (Session Pooler)
# Host: db.llzsulbkbrxbefkqlfsz.supabase.co
# Port: 5432
# Database: postgres
# User: postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.llzsulbkbrxbefkqlfsz.supabase.co:5432/postgres

# Optional: DB schema and table names if you do not use defaults
# SUPABASE_DB_SCHEMA=public
# SUPABASE_CLASSES_TABLE=bst_classes
# SUPABASE_LESSON_PLANS_TABLE=bst_lesson_plans
# SUPABASE_NOTES_TABLE=bst_notes
# SUPABASE_HISTORY_TABLE=bst_app_data_history
# SUPABASE_USER_PROFILES_TABLE=bst_user_profiles
# SUPABASE_SIGNUP_INVITES_TABLE=bst_signup_invites
# SUPABASE_SIGNUP_REQUESTS_TABLE=bst_signup_requests

# Optional: restrict which Supabase users may perform admin actions
# Comma-separated, case-insensitive
# SUPABASE_ALLOWED_EMAILS=admin@example.com,teacher@example.com
# SUPABASE_ALLOWED_ROLES=admin,teacher

# Optional: restrict admin-only pages and approval actions
# Uses app_metadata.role for roles. Defaults to role=admin if unset.
# SUPABASE_ADMIN_EMAILS=admin@example.com
# SUPABASE_ADMIN_ROLES=admin

# Optional: bootstrap the first admin user on server start
# The server will create or update this account with app_metadata.role=admin.
# BST_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BST_BOOTSTRAP_ADMIN_PASSWORD=change-me-now
# BST_BOOTSTRAP_ADMIN_USERNAME=admin

# Optional: SMTP email settings used for invite-request notifications
# If unset, signup requests are still saved but notification emails are skipped.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Bible Study Tools <your-email@example.com>

# Legacy fallback token auth (optional)
# BST_ADMIN_TOKEN=replace-with-strong-random-token

# Security hardening (recommended for production/Fly.io)
# Require auth even when requests appear to come from localhost/proxy.
# Defaults to 1 in production if unset, but explicit is best.
# BST_REQUIRE_ADMIN_ON_LOOPBACK=1

# Enable CSRF protection for remote write requests.
# When enabled, clients must send x-bst-csrf-token.
# BST_ENFORCE_REMOTE_CSRF=1
# BST_CSRF_TOKEN=replace-with-long-random-token

# Optional: only allow trusted browser origins for remote write requests
# when BST_ENFORCE_REMOTE_CSRF=1
# BST_TRUSTED_ORIGINS=https://your-admin-domain.example

# Optional: tune write rate limiting (enabled by default)
# BST_ENABLE_REMOTE_RATE_LIMIT=1
# BST_RATE_LIMIT_WINDOW_MS=60000
# BST_RATE_LIMIT_MAX_REQUESTS=120
